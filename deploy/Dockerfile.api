FROM python:3.12-slim

WORKDIR /srv/backend
ENV PYTHONUNBUFFERED=1 PIP_NO_CACHE_DIR=1

COPY backend/pyproject.toml ./
# 先装依赖层（利用缓存），再拷源码
RUN pip install --upgrade pip && pip install -e . || true
COPY backend/ ./
RUN pip install -e .

EXPOSE 8000
CMD ["uvicorn", "app.main:app", "--host", "0.0.0.0", "--port", "8000"]
