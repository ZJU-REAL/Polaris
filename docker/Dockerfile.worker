# worker 镜像：基于共享 TeX 基础镜像（tectonic + TeX Live + 中文字体，见 Dockerfile.texbase），
# 额外装 LibreOffice（PPT 生成/格式转换，headless 调用），再做 pip 依赖 + 源码拷贝。
# 先构建基础镜像：make texbase
ARG TEXBASE_IMAGE=polaris-texbase:latest
FROM ${TEXBASE_IMAGE}

WORKDIR /srv/backend
ENV PYTHONUNBUFFERED=1 PIP_NO_CACHE_DIR=1

# LibreOffice：只装 impress + 西文字体，避免整套 libreoffice；中文字体基础镜像已带。
# 注意：apt 源沿用基础镜像的 APT_MIRROR 设置（如有）。
RUN apt-get update && apt-get install -y --no-install-recommends \
      libreoffice-impress fonts-dejavu \
    && rm -rf /var/lib/apt/lists/*

# pip 索引镜像：内网访问官方 PyPI 慢/不稳时传国内源（如清华），默认空=官方源
ARG PIP_INDEX_URL=""
COPY src/backend/pyproject.toml ./
RUN pip install ${PIP_INDEX_URL:+-i $PIP_INDEX_URL} --upgrade pip \
    && pip install ${PIP_INDEX_URL:+-i $PIP_INDEX_URL} -e . || true
COPY src/backend/ ./
RUN pip install ${PIP_INDEX_URL:+-i $PIP_INDEX_URL} -e .

CMD ["arq", "worker.settings.WorkerSettings"]
