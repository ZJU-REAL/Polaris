% polaris_acl.sty — 开发用简化样式（unofficial）
% 说明：官方 acl.sty 体积大且下载不可靠，此文件仅以 basic article 类近似 ACL 版式
% （A4 纸型、2.5cm 边距），供 Polaris 平台开发与预览编译使用。
% 正式投稿前请替换为 ACL 官方样式文件。
\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{polaris_acl}[2026/07/14 Polaris simplified ACL-like style (unofficial)]

\RequirePackage[a4paper,margin=2.5cm]{geometry}
\RequirePackage{microtype}

\setlength{\parskip}{2pt}
\setlength{\parindent}{1em}
\renewcommand{\abstractname}{Abstract}

\makeatletter
\renewcommand\section{\@startsection{section}{1}{\z@}%
  {-1.8ex \@plus -0.5ex \@minus -0.2ex}{1.0ex \@plus 0.2ex}%
  {\normalfont\large\bfseries}}
\renewcommand\subsection{\@startsection{subsection}{2}{\z@}%
  {-1.5ex \@plus -0.4ex \@minus -0.2ex}{0.8ex \@plus 0.2ex}%
  {\normalfont\normalsize\bfseries}}
\makeatother

\endinput
