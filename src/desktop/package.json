{
  "name": "polaris-desktop",
  "private": true,
  "version": "0.1.0",
  "description": "Polaris desktop shell (Electron)",
  "main": "dist/main.cjs",
  "scripts": {
    "build:main": "esbuild src/main/index.ts --bundle --platform=node --target=node20 --format=cjs --outfile=dist/main.cjs --external:electron",
    "build:preload": "esbuild src/preload/index.ts --bundle --platform=node --target=node20 --format=cjs --outfile=dist/preload.cjs --external:electron",
    "build:smoke": "esbuild src/smoke.ts --bundle --platform=node --target=node20 --format=cjs --outfile=dist/smoke.cjs --external:electron",
    "build": "npm run build:main && npm run build:preload",
    "smoke": "npm run build:preload && npm run build:smoke && electron dist/smoke.cjs",
    "dev": "npm run build && electron .",
    "lint": "tsc --noEmit",
    "icons": "./scripts/make-icons.sh",
    "dist:mac": "npm run build && electron-builder --mac --universal",
    "dist:win": "npm run build && electron-builder --win",
    "dist:linux": "npm run build && electron-builder --linux"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "esbuild": "^0.24.0",
    "typescript": "^5.5.4"
  }
}
